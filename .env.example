# Leylek — .env.example
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored; this template IS committed for reference.
# Never commit a populated `.env`. Pre-commit gitleaks hook blocks accidents.

# ============================================================================
# Google (OAuth login + Gemini API)
# Setup: https://console.cloud.google.com → APIs & Services → Credentials
# Create OAuth 2.0 Client ID (Web application). Authorized redirect URIs:
#   http://localhost:8788/api/auth/google/callback
#   http://localhost:8788/api/auth/google-ads/callback
#   <prod-url>/api/auth/google/callback
#   <prod-url>/api/auth/google-ads/callback
# Gemini key from: https://aistudio.google.com/apikey
# ============================================================================
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GEMINI_API_KEY=

# ============================================================================
# Google Ads (campaign management on user's behalf)
# Setup: https://ads.google.com → Tools & Settings → API Center
# Apply for developer_token (Test access — instant for testing).
# Create Test Account; 10-digit customer ID without dashes.
# ============================================================================
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_TEST_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ============================================================================
# Meta / Facebook (Marketing API + Conversions API)
# Setup: https://developers.facebook.com → My Apps → Create App (Business type)
# Add Marketing API + Conversions API products.
# Add yourself to App Roles → Testers.
# Test ad account format: act_1234567890 (include act_ prefix).
# ============================================================================
META_APP_ID=
META_APP_SECRET=
META_TEST_AD_ACCOUNT_ID=
META_TEST_PIXEL_ID=
META_TEST_EVENT_CODE=
META_API_VERSION=v21.0

# ============================================================================
# Resend (magic-link e-mail backup auth)
# Setup: https://resend.com → API Keys
# For demo: use onboarding@resend.dev (no domain verification needed).
# ============================================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# ============================================================================
# Cloudflare (Workers, Pages, D1, KV, Durable Objects deploy)
# Setup: https://dash.cloudflare.com → My Profile → API Tokens
# Token scopes: Workers Scripts:Edit, D1:Edit, Workers KV Storage:Edit,
#              Cloudflare Pages:Edit, Account Settings:Read, User Details:Read
# Account ID: right sidebar of any dashboard page.
# ============================================================================
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ============================================================================
# App-internal secrets (generate locally with `openssl rand -base64 64`)
# DO NOT share these between environments; each environment has its own.
# ============================================================================
JWT_SECRET=
AES_KEY_BASE=
SESSION_COOKIE_NAME=leylek_session

# ============================================================================
# URLs (dev defaults; override in prod via Cloudflare Workers Secrets)
# ============================================================================
APP_URL=http://localhost:5173
GATEWAY_URL=http://localhost:8788
