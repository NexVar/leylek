{
  "name": "@leylek/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply leylek-prod --local",
    "db:migrate:prod": "wrangler d1 migrations apply leylek-prod --remote",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "drizzle-kit": "^0.31.5",
    "typescript": "^5.7.0",
    "wrangler": "^4.90.0"
  }
}
